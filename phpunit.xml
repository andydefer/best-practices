<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.0/phpunit.xsd"
    bootstrap="vendor/autoload.php"
    colors="true"
>
    <testsuites>
        <!-- Tests Unitaires du Logger -->
        <testsuite name="Logger Unit">
            <directory suffix="Test.php">./tests/Logger/Unit</directory>
        </testsuite>
        
        <!-- Tests d'Intégration du Logger -->
        <testsuite name="Logger Feature">
            <directory suffix="Test.php">./tests/Logger/Feature</directory>
        </testsuite>
        
        <!-- Tests Unitaires généraux (pour compatibilité) -->
        <testsuite name="Unit">
            <directory suffix="Test.php">./tests/Unit</directory>
        </testsuite>
        
        <!-- Tests d'Intégration généraux (pour compatibilité) -->
        <testsuite name="Feature">
            <directory suffix="Test.php">./tests/Feature</directory>
        </testsuite>
    </testsuites>
    
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_DEBUG" value="true"/>
        
        <!-- Configuration SQLite pour les tests -->
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        
        <!-- Désactiver les drivers non nécessaires -->
        <env name="CACHE_DRIVER" value="array"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="LOG_CHANNEL" value="null"/>
        
        <!-- Optimisations pour les tests -->
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="HASH_VERIFY" value="false"/>
        
        <!-- Configuration spécifique pour le Logger -->
        <env name="LOGGER_PATH" value="/tmp/logger_tests"/>
        <env name="LOGGER_RETENTION_DAYS" value="7"/>
    </php>
</phpunit>